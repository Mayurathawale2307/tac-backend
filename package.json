{
  "name": "tac-backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build": "tsc --noEmit",
    "predev": "npm run prisma:push",
    "dev": "tsx watch index.ts",
    "start": "tsx index.ts",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:push": "node ./scripts/prisma-push.js",
    "postinstall": "prisma generate --schema=prisma/schema.prisma",
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ]
  },
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "@types/multer": "^2.1.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.11.0",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "husky": "^9.1.7",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
