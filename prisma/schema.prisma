generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  googleId      String   @unique
  email         String   @unique
  username      String?  @unique
  name          String?
  bio           String?
  company       String?
  website       String?
  givenName     String?
  familyName    String?
  picture       String?
  emailVerified Boolean  @default(false)
  provider      String   @default("google")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  apiKeys       ApiKey[]
  teams         TeamMember[]
  sentInvites   TeamInvite[] @relation("SentTeamInvites")
  receivedInvites TeamInvite[] @relation("ReceivedTeamInvites")
  sentTeamNotifications TeamNotification[] @relation("SentTeamNotifications")
  teamNotificationRecipients TeamNotificationRecipient[]
}

enum ApiKeyEnvironment {
  DEVELOPMENT
  PRODUCTION
}

enum ApiKeyStatus {
  ACTIVE
  REVOKED
}

model ApiKey {
  id          String            @id @default(cuid())
  userId      String
  teamId      String?
  name        String
  environment ApiKeyEnvironment
  prefix      String
  lastFour    String
  keyHash     String            @unique
  formFields  Json?
  status      ApiKeyStatus      @default(ACTIVE)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  lastUsedAt  DateTime?
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  team        Team?             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  messages    Message[]

  @@index([userId, createdAt])
  @@index([teamId, createdAt])
}

model Message {
  id          String   @id @default(cuid())
  apiKeyId    String
  sender      String
  email       String
  subject     String?
  phone       String?
  website     String?
  message     String
  customFields Json?
  origin      String?
  userAgent   String?
  ipAddress   String?
  receivedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  apiKey      ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  @@index([apiKeyId, receivedAt])
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model Team {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  members   TeamMember[]
  apiKeys   ApiKey[]
  invites   TeamInvite[]
  notifications TeamNotification[]

  @@index([createdAt])
}

model TeamInvite {
  id             String       @id @default(cuid())
  teamId         String
  invitedById    String
  invitedUserId  String
  role           TeamRole     @default(MEMBER)
  status         InviteStatus @default(PENDING)
  createdAt      DateTime     @default(now())
  respondedAt    DateTime?

  team           Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  invitedBy      User         @relation("SentTeamInvites", fields: [invitedById], references: [id], onDelete: Cascade)
  invitedUser    User         @relation("ReceivedTeamInvites", fields: [invitedUserId], references: [id], onDelete: Cascade)

  @@unique([teamId, invitedUserId])
  @@index([invitedUserId, status])
  @@index([teamId, status])
}

model TeamMember {
  id        String   @id @default(cuid())
  teamId    String
  userId    String
  role      TeamRole @default(MEMBER)
  joinedAt  DateTime @default(now())
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId, teamId])
}

model TeamNotification {
  id        String   @id @default(cuid())
  teamId     String
  senderId   String
  title      String
  message    String
  createdAt  DateTime @default(now())
  team       Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  sender     User      @relation("SentTeamNotifications", fields: [senderId], references: [id], onDelete: Cascade)
  recipients TeamNotificationRecipient[]

  @@index([teamId, createdAt])
  @@index([senderId, createdAt])
}

model TeamNotificationRecipient {
  id             String   @id @default(cuid())
  notificationId String
  userId         String
  readAt         DateTime?
  createdAt      DateTime @default(now())
  notification   TeamNotification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notificationId, userId])
  @@index([userId, createdAt])
  @@index([userId, readAt])
}
